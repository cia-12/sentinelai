# SentinelAI Configuration
# Copy this to .env and customize values

# API Configuration
SENTINEL_HOST=0.0.0.0
SENTINEL_PORT=8000
SENTINEL_RELOAD=False

# Authentication
SENTINEL_API_KEY=demo-key-change-in-production
SENTINEL_REQUIRE_AUTH=False

# Event Generation
SENTINEL_EPS=6
SENTINEL_ALERTS_MAXLEN=500

# Detection Thresholds
SENTINEL_BRUTE_THRESHOLD=50
SENTINEL_C2_THRESHOLD=0.55
SENTINEL_IF_CONTAMINATION=0.08

# Logging
SENTINEL_LOG_LEVEL=INFO

# LLM / Playbooks
ANTHROPIC_API_KEY=

# Storage & Persistence
SENTINEL_PERSIST=True
SENTINEL_DB_URL=sqlite:///data/sentinelai.db
SENTINEL_METRICS=True

# Demo Mode
SENTINEL_DEMO_MODE=True
